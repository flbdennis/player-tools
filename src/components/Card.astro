---
// 卡片组件 - 统一白色磨砂卡片、暖色边框和柔和阴影，贴近 UI 图卡片质感
const {
  class: className = '',
  hover = true,
  padding = 'normal',
} = Astro.props;

const paddingClass =
  padding === 'large'
    ? 'p-6 md:p-7'
    : padding === 'small'
      ? 'p-4 md:p-5'
      : 'p-5 md:p-6';

const hoverStyles = hover ? 'hover:-translate-y-1 hover:shadow-[0_20px_46px_rgba(119,71,255,0.12)]' : '';
---
<div class={`mt-card transition-all duration-300 ${hoverStyles} ${paddingClass} ${className}`}>
  <slot />
</div>
