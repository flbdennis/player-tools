---
// InfoImageCard 组件 - 信息说明卡片，左侧可爬取文本、右侧复用现有 3D 插图素材
const { card } = Astro.props;
---

<article class="mt-card grid grid-cols-1 items-center gap-3 overflow-visible px-5 py-5 md:min-h-[168px] md:grid-cols-[minmax(0,1fr)_250px] md:gap-4 md:px-6 md:py-6">
  <div class="relative z-10 min-w-0 self-center">
    <h2 class="mb-3 text-[17px] font-black tracking-[-0.03em] text-gray-950 md:text-[18px]">{card.title}</h2>
    {card.paragraphs && (
      <div class="space-y-2 text-[14px] font-semibold leading-snug text-gray-800">
        {card.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    )}
    {card.bullets && (
      <ul class="space-y-1.5 text-[14px] font-semibold leading-snug text-gray-800">
        {card.bullets.map((bullet) => (
          <li class="flex items-start gap-2.5">
            <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-gray-950"></span>
            <span class="min-w-0 flex-1">{bullet}</span>
          </li>
        ))}
      </ul>
    )}
  </div>
  <div class="flex min-h-[104px] items-center justify-center self-center md:min-h-[150px] md:justify-end">
    <img
      src={card.image}
      alt={card.imageAlt}
      width="390"
      height="292"
      loading="lazy"
      decoding="async"
      class="h-auto w-full max-w-[190px] object-contain drop-shadow-[0_18px_26px_rgba(119,71,255,0.12)] md:max-h-[205px] md:max-w-[315px]"
    />
  </div>
</article>
