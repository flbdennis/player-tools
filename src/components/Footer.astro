---
// Footer 组件 - 站点底部，复用导航配置并避免假社交链接
import { site } from '../config/site.js';
import { footerNav } from '../config/nav.js';
import Icon from './Icon.astro';
import Container from './Container.astro';
---

<footer class="bg-white/70 border-t border-orange-100/60">
  <Container class="py-5 md:py-6">
    <div class="grid grid-cols-2 gap-x-5 gap-y-6 md:grid-cols-12 md:gap-6">
      {/* Logo 和站点说明，文案保持英文且可被搜索引擎抓取 */}
      <div class="col-span-2 md:col-span-3">
        <a href="/" class="inline-block mb-2" aria-label={`${site.name} home`}>
          <img
            src={site.logo}
            alt={`${site.name} logo`}
            width="128"
            height="28"
            class="h-6 w-auto"
            loading="lazy"
          />
        </a>
        <p class="text-[12px] font-medium text-gray-600 leading-snug max-w-[230px]">
          Free browser-based video player tools for testing public or authorized M3U8, MP4 and MPEG-DASH links.
        </p>
        {/* 只展示真实可用的联系入口，避免假社交账号影响审核 */}
        <a
          href={`mailto:${site.email}`}
          class="mt-3 inline-flex h-7 w-7 items-center justify-center rounded-full bg-gray-100 text-gray-900 hover:bg-violet-50 hover:text-violet-700 transition-colors"
          aria-label="Email MetisTools"
        >
          <Icon name="Mail" size={16} strokeWidth={2.2} />
        </a>
      </div>

      {/* Footer 导航分组全部来自配置，保证不会出现无效链接 */}
      <div class="col-span-1 md:col-span-2">
        <h3 class="text-[12px] font-extrabold text-gray-950 mb-2">{footerNav.tools.title}</h3>
        <ul class="space-y-1">
          {footerNav.tools.links.map((link) => (
            <li><a href={link.href} class="text-[12px] font-semibold text-gray-600 hover:text-violet-700 transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="col-span-1 md:col-span-2">
        <h3 class="text-[12px] font-extrabold text-gray-950 mb-2">{footerNav.guides.title}</h3>
        <ul class="space-y-1">
          {footerNav.guides.links.map((link) => (
            <li><a href={link.href} class="text-[12px] font-semibold text-gray-600 hover:text-violet-700 transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="col-span-1 md:col-span-2">
        <h3 class="text-[12px] font-extrabold text-gray-950 mb-2">{footerNav.about.title}</h3>
        <ul class="space-y-1">
          {footerNav.about.links.map((link) => (
            <li><a href={link.href} class="text-[12px] font-semibold text-gray-600 hover:text-violet-700 transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="col-span-1 md:col-span-3">
        <h3 class="text-[12px] font-extrabold text-gray-950 mb-2">Contact</h3>
        <p class="text-[12px] font-semibold text-gray-600 leading-relaxed mb-1">Questions or suggestions?</p>
        <a href={`mailto:${site.email}`} class="text-[12px] font-bold text-gray-700 hover:text-violet-700 transition-colors break-all">
          {site.email}
        </a>
      </div>
    </div>

    {/* 版权信息不能裁切，保持自然高度以确保审核和可信度 */}
    <div class="pt-4 text-center">
      <p class="text-[11px] font-medium text-gray-500">© 2024 {site.name}. All rights reserved.</p>
    </div>
  </Container>
</footer>
