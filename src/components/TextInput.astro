---
// 文本输入组件 - 封装原生 input，统一 label、图标、校验状态和可访问性，供所有工具表单复用
import FormField from './FormField.astro';
import Icon from './Icon.astro';

const {
  type = 'text',
  name,
  id,
  label,
  hint,
  placeholder,
  value,
  error,
  required = false,
  disabled = false,
  readonly = false,
  autocomplete,
  inputmode,
  pattern,
  min,
  max,
  step,
  leftIcon,
  rightIcon,
  class: className = '',
  inputClass = '',
  describedBy = '',
  ariaLabel,
} = Astro.props;

const hintId = hint && id ? `${id}-hint` : '';
const errorId = error && id ? `${id}-error` : '';
const describedByValue = [describedBy, error ? errorId : hintId].filter(Boolean).join(' ') || undefined;
const errorStyles = error
  ? 'border-red-400 focus:border-red-500 focus:ring-red-100'
  : 'border-orange-100 focus:border-violet-300 focus:ring-violet-100';
const iconPaddingStyles = `${leftIcon ? 'pl-10' : 'pl-4'} ${rightIcon ? 'pr-10' : 'pr-4'}`;
---

<FormField id={id} label={label} hint={hint} error={error} required={required} class={className}>
  <div class="relative">
    {leftIcon && (
      <span class="pointer-events-none absolute left-3 top-1/2 z-10 -translate-y-1/2 text-violet-700">
        <Icon name={leftIcon} size={16} color="currentColor" strokeWidth={2.4} />
      </span>
    )}
    <input
      type={type}
      name={name}
      id={id}
      placeholder={placeholder}
      value={value}
      required={required}
      disabled={disabled}
      readonly={readonly}
      autocomplete={autocomplete}
      inputmode={inputmode}
      pattern={pattern}
      min={min}
      max={max}
      step={step}
      aria-label={ariaLabel}
      aria-invalid={error ? 'true' : undefined}
      aria-describedby={describedByValue}
      class={`h-[38px] w-full rounded-lg border bg-white ${iconPaddingStyles} text-[13px] font-semibold text-gray-700 placeholder-gray-400 shadow-inner shadow-orange-50/70 transition-all duration-200 focus:outline-none focus:ring-4 disabled:cursor-not-allowed disabled:bg-gray-50 disabled:text-gray-400 ${errorStyles} ${inputClass}`}
    />
    {rightIcon && (
      <span class="pointer-events-none absolute right-3 top-1/2 z-10 -translate-y-1/2 text-gray-400">
        <Icon name={rightIcon} size={16} color="currentColor" strokeWidth={2.4} />
      </span>
    )}
  </div>
</FormField>
