---
// PlayerGuideSteps 组件 - 渲染播放器使用步骤，统一序号和 Lucide 图标样式
import Icon from './Icon.astro';
const { guide } = Astro.props;
---

<section class="py-3" aria-labelledby="guide-title">
  <h2 id="guide-title" class="mb-2.5 text-[17px] font-black tracking-[-0.03em] text-gray-950">{guide.title}</h2>
  <div class="space-y-1.5">
    {guide.steps.map((step, index) => (
      <div class="grid grid-cols-[22px_28px_1fr] items-center gap-2.5">
        <span class="flex h-[22px] w-[22px] items-center justify-center rounded-full bg-[linear-gradient(135deg,#6f42ff,#8c55ff)] text-[12px] font-black text-white shadow-md shadow-violet-200/70">
          {index + 1}
        </span>
        <span class="flex h-[28px] w-[28px] items-center justify-center rounded-full bg-white text-violet-700 shadow-md shadow-orange-100/80 ring-1 ring-orange-100">
          <Icon name={step.icon} size={16} color="currentColor" strokeWidth={2.5} />
        </span>
        <p class="text-[13px] font-semibold leading-snug text-gray-800">
          <span class="font-black text-gray-950">{step.title}: </span>{step.description}
        </p>
      </div>
    ))}
  </div>
</section>
