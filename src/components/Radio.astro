---
// 单选组组件 - 用于转换模式、输出策略和下载范围选择，统一 fieldset 语义和错误状态
import Icon from './Icon.astro';

const {
  name,
  legend,
  hint,
  error,
  options = [],
  value = '',
  required = false,
  disabled = false,
  class: className = '',
  optionClass = '',
} = Astro.props;

const normalizedOptions = options.map((option) => (
  typeof option === 'string'
    ? { label: option, value: option }
    : option
));
const baseId = String(name || 'radio').replace(/[^a-zA-Z0-9_-]+/g, '-');
const hintId = hint ? `${baseId}-hint` : '';
const errorId = error ? `${baseId}-error` : '';
const describedByValue = [error ? errorId : hintId].filter(Boolean).join(' ') || undefined;
---

<fieldset
  class={`w-full space-y-2 ${className}`}
  aria-invalid={error ? 'true' : undefined}
  aria-describedby={describedByValue}
  data-form-field
  data-invalid={error ? 'true' : 'false'}
>
  {legend && (
    <legend class="text-[13px] font-extrabold leading-snug text-gray-900">
      {legend}
      {required && <span class="ml-1 text-red-500" aria-hidden="true">*</span>}
    </legend>
  )}

  <div class="grid gap-2">
    {normalizedOptions.map((option, index) => {
      const optionId = option.id || `${baseId}-${String(option.value || index).replace(/[^a-zA-Z0-9_-]+/g, '-')}`;
      const isDisabled = disabled || option.disabled;
      return (
        <label
          for={optionId}
          class={`flex gap-3 rounded-lg border bg-white/80 p-3 shadow-sm shadow-orange-50/70 transition-colors ${error ? 'border-red-200' : 'border-orange-100 hover:border-violet-200'} ${isDisabled ? 'cursor-not-allowed opacity-60' : 'cursor-pointer'} ${optionClass}`}
        >
          <input
            id={optionId}
            name={name}
            type="radio"
            value={option.value}
            checked={String(option.value) === String(value)}
            required={required}
            disabled={isDisabled}
            class="mt-0.5 h-4 w-4 shrink-0 border-orange-200 text-violet-700 accent-violet-700 focus:ring-2 focus:ring-violet-200"
          />
          <span class="min-w-0">
            <span class="block text-[13px] font-extrabold leading-snug text-gray-900">{option.label}</span>
            {option.description && (
              <span class="mt-1 block text-[12.5px] font-semibold leading-snug text-gray-500">
                {option.description}
              </span>
            )}
          </span>
        </label>
      );
    })}
  </div>

  {hint && !error && (
    <p id={hintId} class="text-[12.5px] font-semibold leading-snug text-gray-500">{hint}</p>
  )}
  {error && (
    <p id={errorId} class="flex items-start gap-1.5 text-[12.5px] font-bold leading-snug text-red-500">
      <span class="mt-[1px] inline-flex shrink-0 text-red-500">
        <Icon name="AlertCircle" size={14} color="currentColor" strokeWidth={2.3} />
      </span>
      <span>{error}</span>
    </p>
  )}
</fieldset>
