---
// 下拉选择组件 - 封装原生 select，统一 label、错误提示、可访问性和移动端触控尺寸
import FormField from './FormField.astro';
import Icon from './Icon.astro';

const {
  id,
  name,
  label,
  hint,
  error,
  required = false,
  disabled = false,
  value = '',
  placeholder = '',
  options = [],
  class: className = '',
  selectClass = '',
  describedBy = '',
  ariaLabel,
} = Astro.props;

const hintId = hint && id ? `${id}-hint` : '';
const errorId = error && id ? `${id}-error` : '';
const describedByValue = [describedBy, error ? errorId : hintId].filter(Boolean).join(' ') || undefined;
const normalizedOptions = options.map((option) => (
  typeof option === 'string'
    ? { label: option, value: option }
    : option
));
const selectStateStyles = error
  ? 'border-red-400 focus:border-red-500 focus:ring-red-100'
  : 'border-orange-100 focus:border-violet-300 focus:ring-violet-100';
---

<FormField id={id} label={label} hint={hint} error={error} required={required} class={className}>
  <div class="relative">
    <select
      id={id}
      name={name}
      required={required}
      disabled={disabled}
      aria-label={ariaLabel}
      aria-invalid={error ? 'true' : undefined}
      aria-describedby={describedByValue}
      class={`h-[38px] w-full appearance-none rounded-lg border bg-white px-4 pr-10 text-[13px] font-semibold text-gray-700 shadow-inner shadow-orange-50/70 transition-all duration-200 focus:outline-none focus:ring-4 disabled:cursor-not-allowed disabled:bg-gray-50 disabled:text-gray-400 ${selectStateStyles} ${selectClass}`}
    >
      {placeholder && <option value="" disabled={required} selected={!value}>{placeholder}</option>}
      {normalizedOptions.map((option) => (
        <option value={option.value} selected={String(option.value) === String(value)} disabled={option.disabled}>
          {option.label}
        </option>
      ))}
    </select>
    <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">
      <Icon name="ChevronDown" size={15} color="currentColor" strokeWidth={2.5} />
    </span>
  </div>
</FormField>
