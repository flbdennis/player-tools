---
// PlayerTabs 组件 - 统一工具页 Tab 导航；也支持 Analyzer 内部按钮式切换，保证同一类切换控件共用样式
import Tooltip from './Tooltip.astro';

const {
  tabs = [],
  activeId = 'm3u8',
  mode = 'links',
  ariaLabel = 'Player type navigation',
  buttonPrefix = 'player-tab',
  class: className = '',
} = Astro.props;

const shouldUseMobileGrid = mode === 'links' && tabs.length >= 4;
const navClass = shouldUseMobileGrid
  ? 'grid grid-cols-2 gap-1.5 md:flex md:flex-nowrap md:gap-2'
  : 'flex flex-nowrap gap-1.5 md:gap-2';
const baseTabClass = 'inline-flex h-[32px] w-full min-w-0 flex-1 items-center justify-center rounded-md border px-2 text-[12px] font-extrabold leading-none whitespace-nowrap transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-violet-300 focus:ring-offset-2 focus:ring-offset-white md:h-[30px] md:w-auto md:min-w-[96px] md:flex-none md:px-3 md:text-[13px]';
const stateTabClass = 'data-[state=active]:border-violet-600 data-[state=active]:bg-[linear-gradient(90deg,#5a37ff_0%,#7a2cff_55%,#9f22ff_100%)] data-[state=active]:text-white data-[state=active]:shadow-lg data-[state=active]:shadow-violet-200/70 data-[state=inactive]:border-orange-100 data-[state=inactive]:bg-white/85 data-[state=inactive]:text-gray-950 data-[state=inactive]:hover:border-violet-200 data-[state=inactive]:hover:text-violet-700';
---

<nav class={`${navClass} ${className}`} aria-label={ariaLabel} role={mode === 'buttons' ? 'tablist' : undefined}>
  {tabs.map((tab) => {
    const tooltipText = tab.tooltip || tab.description || '';
    const tooltipId = tooltipText ? `${buttonPrefix}-${tab.id}-tooltip` : undefined;
    const state = tab.id === activeId ? 'active' : 'inactive';
    const tabClass = `${baseTabClass} ${stateTabClass}`;
    const content = mode === 'buttons' ? (
      <button
        type="button"
        id={`${buttonPrefix}-${tab.id}`}
        data-player-tab-button
        data-tab-id={tab.id}
        data-state={state}
        role="tab"
        aria-selected={tab.id === activeId ? 'true' : 'false'}
        aria-describedby={tooltipId}
        class={tabClass}
      >
        {tab.label}
      </button>
    ) : (
      <a
        href={tab.href}
        aria-current={tab.id === activeId ? 'page' : undefined}
        aria-describedby={tooltipId}
        data-state={state}
        class={tabClass}
      >
        {tab.label}
      </a>
    );

    return tooltipText ? (
      <Tooltip id={tooltipId} text={tooltipText} position="bottom" class="flex min-w-0 w-full md:w-auto md:flex-none" tooltipClass="left-1/2 -translate-x-1/2">
        {content}
      </Tooltip>
    ) : content;
  })}
</nav>
