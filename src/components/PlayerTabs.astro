---
// PlayerTabs 组件 - 统一工具页 Tab 导航，当前页高亮，其余 Tab 使用真实路由跳转
const { tabs = [], activeId = 'm3u8' } = Astro.props;
---

<nav class="flex flex-nowrap gap-1.5 md:gap-2" aria-label="Player type navigation">
  {tabs.map((tab) => (
    <a
      href={tab.href}
      aria-current={tab.id === activeId ? 'page' : undefined}
      class={`inline-flex h-[30px] min-w-0 flex-1 items-center justify-center rounded-md border px-1.5 text-[12px] font-extrabold transition-all duration-200 md:h-[30px] md:min-w-[96px] md:flex-none md:px-3 md:text-[13px] ${
        tab.id === activeId
          ? 'border-violet-600 bg-[linear-gradient(90deg,#5a37ff_0%,#7a2cff_55%,#9f22ff_100%)] text-white shadow-lg shadow-violet-200/70'
          : 'border-orange-100 bg-white/85 text-gray-950 hover:border-violet-200 hover:text-violet-700'
      }`}
    >
      {tab.label}
    </a>
  ))}
</nav>
