---
// SEO 组件 - 统一管理页面的 title、description、canonical、Open Graph、Twitter metadata 和 JSON-LD
import { site, defaultSeo } from '../config/site.js';

const {
  title,
  description,
  canonical,
  ogImage,
  ogImageWidth = defaultSeo.ogImageWidth,
  ogImageHeight = defaultSeo.ogImageHeight,
  ogType = 'website',
  noindex = false,
  robots,
  disableCanonical = false,
  jsonLd = [],
  ogLocale = 'en_US',
  alternateLinks = [],
} = Astro.props;

const pageTitle = title
  ? `${title} - ${site.name}`
  : defaultSeo.defaultTitle;
const pageDescription = description || defaultSeo.description;
const normalizedPathname = Astro.url.pathname === '/' ? '/' : Astro.url.pathname.replace(/\/+$/, '');
const fallbackCanonical = `${site.domain}${normalizedPathname}`;
const pageCanonical = canonical || fallbackCanonical;
const shouldRenderCanonical = !disableCanonical && canonical !== null;
const toAbsoluteUrl = (value) => {
  if (!value) return '';
  return value.startsWith('http://') || value.startsWith('https://')
    ? value
    : `${site.domain}${value}`;
};
const pageOgImage = toAbsoluteUrl(ogImage || defaultSeo.ogImage);
const robotsContent = robots || (noindex ? 'noindex, follow' : 'index, follow');
---

{/* 基础 Meta */}
<title>{pageTitle}</title>
<meta name="description" content={pageDescription} />
<meta name="author" content={defaultSeo.author} />

{/* Canonical */}
{shouldRenderCanonical && <link rel="canonical" href={pageCanonical} />}

{/* Alternate language links */}
{alternateLinks.length > 0 && alternateLinks.map((link) => (
  <link rel="alternate" hreflang={link.hreflang} href={link.href} />
))}

{/* Robots */}
<meta name="robots" content={robotsContent} />

{/* Open Graph */}
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDescription} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={pageCanonical} />
<meta property="og:image" content={pageOgImage} />
<meta property="og:image:width" content={String(ogImageWidth)} />
<meta property="og:image:height" content={String(ogImageHeight)} />
<meta property="og:site_name" content={site.name} />
<meta property="og:locale" content={ogLocale} />

{/* Twitter Card */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={pageDescription} />
<meta name="twitter:image" content={pageOgImage} />

{/* Favicon */}
<link rel="icon" type="image/x-icon" href={site.favicon} />
<link rel="icon" type="image/svg+xml" href="/logo/logo.svg" />

{/* JSON-LD 结构化数据 */}
{jsonLd.length > 0 && jsonLd.map((item) => (
  <script type="application/ld+json" set:html={JSON.stringify(item)} />
))}
