---
// PermissionNotice 组件 - 统一授权与版权提示，首页 Quick Test 和播放器页共用
import Icon from './Icon.astro';

const {
  text,
  class: className = '',
  iconColor = '#8b5cf6',
} = Astro.props;
---

<p class={`flex items-start gap-2 text-[11px] font-semibold leading-relaxed text-gray-600 ${className}`}>
  <span class="mt-0.5 shrink-0">
    <Icon name="Shield" size={15} color={iconColor} strokeWidth={2.3} />
  </span>
  <span>{text}</span>
</p>
