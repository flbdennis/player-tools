---
// Header 组件 - 站点顶部导航，严格复用站点配置与 Icon 组件
import { site } from '../config/site.js';
import { headerNav } from '../config/nav.js';
import Icon from './Icon.astro';
import Container from './Container.astro';
---

<header class="sticky top-0 z-50 bg-white/88 backdrop-blur-xl border-b border-orange-100/60">
  <Container variant="header">
    <div class="flex items-center justify-between h-[58px]">
      {/* Logo 使用 public/logo 中的既有素材，不重绘、不改色 */}
      <a href="/" class="flex items-center shrink-0" aria-label={`${site.name} home`}>
        <img
          src={site.logo}
          alt={`${site.name} logo`}
          width="137"
          height="30"
          class="h-[30px] w-auto"
        />
      </a>

      {/* 主导航只渲染一份 DOM：桌面端横向展示，移动端通过按钮切换为浮层，减少抓取噪音和读屏重复 */}
      <nav
        id="primary-navigation"
        class="hidden fixed inset-x-0 top-[58px] z-[60] max-h-[calc(100vh-58px)] overflow-y-auto border-t border-orange-100 bg-white/96 px-4 py-4 shadow-2xl shadow-violet-100/40 backdrop-blur-xl md:static md:z-auto md:flex md:max-h-none md:overflow-visible md:border-0 md:bg-transparent md:p-0 md:shadow-none md:backdrop-blur-0 items-stretch md:items-center gap-1 md:gap-8"
        aria-label="Primary navigation"
        data-primary-nav
      >
        {headerNav.map((item, index) => (
          <div class="relative group" data-nav-dropdown={item.children ? '' : undefined}>
            {item.children ? (
              <>
                <button
                  type="button"
                  id={`nav-trigger-${index}`}
                  class="flex w-full items-center justify-between gap-1.5 rounded-xl px-4 py-3 text-left text-sm font-bold text-gray-900 transition-colors hover:bg-violet-50 hover:text-violet-700 md:w-auto md:justify-start md:rounded-none md:px-0 md:py-0 md:text-[14px] md:text-gray-950 md:hover:bg-transparent"
                  aria-haspopup="true"
                  aria-expanded="false"
                  aria-controls={`nav-menu-${index}`}
                  data-nav-dropdown-trigger
                >
                  {item.label}
                  <Icon name="ChevronDown" size={14} strokeWidth={2.4} />
                </button>
                {/* 下拉菜单只使用真实工具页链接，避免死链 */}
                <div
                  id={`nav-menu-${index}`}
                  class="hidden pl-4 space-y-1 md:invisible md:absolute md:left-1/2 md:top-full md:mt-4 md:block md:w-48 md:-translate-x-1/2 md:space-y-0 md:rounded-2xl md:border md:border-orange-100 md:bg-white md:py-2 md:pl-0 md:opacity-0 md:shadow-xl md:shadow-violet-100/60 md:transition-all md:duration-200 md:group-hover:visible md:group-hover:opacity-100 md:group-focus-within:visible md:group-focus-within:opacity-100"
                  role="menu"
                  aria-labelledby={`nav-trigger-${index}`}
                  data-nav-dropdown-menu
                >
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block rounded-xl px-4 py-2.5 text-sm font-semibold text-gray-600 transition-colors hover:bg-violet-50 hover:text-violet-700 md:rounded-none md:text-gray-700"
                      role="menuitem"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </>
            ) : (
              <a
                href={item.href}
                class="block rounded-xl px-4 py-3 text-sm font-bold text-gray-900 transition-colors hover:bg-violet-50 hover:text-violet-700 md:rounded-none md:px-0 md:py-0 md:text-[14px] md:text-gray-950 md:hover:bg-transparent"
              >
                {item.label}
              </a>
            )}
          </div>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        {/* 多语言切换暂不开放，移除不可用入口，避免用户误以为当前站点已有语言切换功能 */}

        {/* 移动端菜单按钮使用统一 Icon 组件，保证图标来源和可访问名称一致 */}
        <button
          type="button"
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-xl hover:bg-violet-50 transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="primary-navigation"
        >
          <Icon name="Menu" size={24} color="currentColor" strokeWidth={2.4} class="text-gray-950" />
        </button>
      </div>
    </div>
  </Container>

</header>

<script>
  // 主导航下拉菜单：同一份 DOM 同时服务桌面和移动端，减少重复导航文本和读屏重复
  const navDropdowns = document.querySelectorAll('[data-nav-dropdown]');

  function setDropdownState(dropdown, isOpen) {
    const trigger = dropdown.querySelector('[data-nav-dropdown-trigger]');
    const menu = dropdown.querySelector('[data-nav-dropdown-menu]');
    if (!trigger || !menu) return;

    trigger.setAttribute('aria-expanded', String(isOpen));
    menu.classList.toggle('opacity-100', isOpen);
    menu.classList.toggle('visible', isOpen);
    menu.classList.toggle('opacity-0', !isOpen);
    menu.classList.toggle('invisible', !isOpen);
    menu.classList.toggle('hidden', !isOpen && window.matchMedia('(max-width: 767px)').matches);
  }

  function closeDropdowns(exceptDropdown = null) {
    navDropdowns.forEach((dropdown) => {
      if (dropdown !== exceptDropdown) {
        setDropdownState(dropdown, false);
      }
    });
  }

  navDropdowns.forEach((dropdown) => {
    const trigger = dropdown.querySelector('[data-nav-dropdown-trigger]');
    const menu = dropdown.querySelector('[data-nav-dropdown-menu]');
    if (!trigger || !menu) return;

    trigger.addEventListener('click', (event) => {
      event.stopPropagation();
      const shouldOpen = trigger.getAttribute('aria-expanded') !== 'true';
      closeDropdowns(dropdown);
      setDropdownState(dropdown, shouldOpen);
    });

    trigger.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowDown') {
        event.preventDefault();
        closeDropdowns(dropdown);
        setDropdownState(dropdown, true);
        menu.querySelector('a')?.focus();
      }

      if (event.key === 'Escape') {
        setDropdownState(dropdown, false);
        trigger.focus();
      }
    });

    menu.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        setDropdownState(dropdown, false);
        trigger.focus();
      }
    });

    dropdown.addEventListener('focusout', () => {
      window.setTimeout(() => {
        if (!dropdown.contains(document.activeElement)) {
          setDropdownState(dropdown, false);
        }
      }, 0);
    });
  });

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof Node)) return;
    const clickedInsideDropdown = Array.from(navDropdowns).some((dropdown) => dropdown.contains(target));
    if (!clickedInsideDropdown) {
      closeDropdowns();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeDropdowns();
    }
  });

  // 移动端菜单展开/收起逻辑，保持无框架依赖和低 JS 体积
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const primaryNavigation = document.getElementById('primary-navigation');

  function closeMobileMenu() {
    if (!mobileMenuBtn || !primaryNavigation) return;
    mobileMenuBtn.setAttribute('aria-expanded', 'false');
    primaryNavigation.classList.add('hidden');
    closeDropdowns();
  }

  if (mobileMenuBtn && primaryNavigation) {
    mobileMenuBtn.addEventListener('click', (event) => {
      event.stopPropagation();
      const isExpanded = mobileMenuBtn.getAttribute('aria-expanded') === 'true';
      mobileMenuBtn.setAttribute('aria-expanded', String(!isExpanded));
      primaryNavigation.classList.toggle('hidden', isExpanded);
    });

    // 移动端导航打开后，点击导航外部区域自动关闭，避免菜单遮挡页面内容
    document.addEventListener('click', (event) => {
      const target = event.target;
      const isOpen = mobileMenuBtn.getAttribute('aria-expanded') === 'true';
      if (!isOpen || !(target instanceof Node)) return;

      if (!primaryNavigation.contains(target) && !mobileMenuBtn.contains(target)) {
        closeMobileMenu();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeMobileMenu();
      }
    });

    primaryNavigation.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMobileMenu);
    });
  }
</script>
