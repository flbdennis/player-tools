---
// Contact 页面 - 联系方式和反馈说明，提升站点可信度与 AdSense 审核可读性
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site.js';
import Container from '../components/Container.astro';

const pageTitle = 'Contact';
const pageDescription = `Contact ${site.name} for questions, feedback, policy concerns or issues related to our M3U8, MP4 and MPEG-DASH video player tools.`;
const canonical = `${site.domain}/contact`;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  enableAds={false}
>
  <Container class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Contact MetisTools
      </h1>
      <p class="text-lg text-gray-500 mb-10 leading-relaxed">
        Contact us if you have questions about the video player tools, notice a
        playback issue, want to report misuse or need clarification about our
        responsible testing policy.
      </p>

      <div class="bg-white/80 backdrop-blur-sm rounded-xl border border-orange-100 shadow-sm shadow-orange-100/60 p-8 md:p-10">
        <div class="space-y-6">
          <div>
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              Email
            </h2>
            <a
              href={`mailto:${site.email}`}
              class="text-lg text-violet-600 hover:text-violet-700 transition-colors break-all"
            >
              {site.email}
            </a>
          </div>

          <div class="pt-6 border-t border-gray-100">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              What to Include
            </h2>
            <p class="text-gray-600 leading-relaxed">
              If you are reporting a playback problem, include the tool page,
              browser name, device type, error message and whether the link is
              M3U8, MP4 or MPD. Do not send private, confidential or
              unauthorized video links by email.
            </p>
          </div>

          <div class="pt-6 border-t border-gray-100">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              Response Time
            </h2>
            <p class="text-gray-600 leading-relaxed">
              We review messages as soon as practical. Response time may vary
              depending on the question and the amount of technical context
              provided.
            </p>
          </div>
        </div>
      </div>
    </div>
  </Container>
</BaseLayout>
