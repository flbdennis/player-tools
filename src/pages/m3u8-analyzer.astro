---
// M3U8 Analyzer 页面 - 低风险工具与现有 Player 页面平级，承载 M3U8/HLS 和 DASH/MPD 两种 Analyzer
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import ToolBreadcrumb from '../components/ToolBreadcrumb.astro';
import ToolHero from '../components/ToolHero.astro';
import AnalyzerShell from '../components/AnalyzerShell.astro';
import PlayerGuideSteps from '../components/PlayerGuideSteps.astro';
import InfoImageCard from '../components/InfoImageCard.astro';
import PlayerFAQ from '../components/PlayerFAQ.astro';
import { site } from '../config/site.js';
import { analyzerPage } from '../config/analyzer.js';

const pageTitle = analyzerPage.seo.title;
const pageDescription = analyzerPage.seo.description;
const canonical = `${site.domain}/m3u8-analyzer`;

// 结构化数据 - 标记该页面为浏览器内 stream manifest 分析工具，不声明下载或转换能力
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: pageTitle,
    url: canonical,
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Web',
    description: pageDescription,
    inLanguage: site.language,
    screenshot: `${site.domain}/imgs/m3u8_2.webp`,
    featureList: [
      'Browser-side M3U8/HLS playlist analysis for public or authorized manifests',
      'DASH/MPD manifest inspection for periods, adaptation sets and representations',
      'MP4 link response checks with browser-safe HEAD metadata',
      'Smart sample segment checks for obvious access, response and permission issues',
      'Warnings for encryption tags, content protection markers and common manifest structure issues',
    ],
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: `${site.domain}/`,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'M3U8 Analyzer',
        item: canonical,
      },
    ],
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} jsonLd={jsonLd}>
  <div class="pt-2 md:pt-3">
    <Container>
      <ToolBreadcrumb items={analyzerPage.breadcrumb} />
      <ToolHero hero={analyzerPage.hero} titleId="analyzer-page-title" />

      <AnalyzerShell tabs={analyzerPage.tabs} activeId="analyzer" analyzer={analyzerPage.analyzer} />
      <PlayerGuideSteps guide={analyzerPage.guide} />

      <div class="space-y-4">
        {analyzerPage.infoCards.map((card) => (
          <InfoImageCard card={card} />
        ))}
      </div>

      <PlayerFAQ faq={analyzerPage.faq} />
    </Container>
  </div>
</BaseLayout>
