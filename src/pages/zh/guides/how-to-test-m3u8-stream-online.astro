---
// 中文 Guide：在线测试 M3U8 直播流 - 仅链接中文页面和中文工具页
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import Button from '../../../components/Button.astro';
import { site } from '../../../config/site.js';
import { zhGuideArticles } from '../../../config/zhGuideArticles.js';

const article = zhGuideArticles.find((item) => item.slug === 'how-to-test-m3u8-stream-online');
const canonical = `${site.domain}${article.href}`;
---

<BaseLayout title={article.title} description={article.description} canonical={canonical} lang="zh-CN" ogLocale="zh_CN">
  <Container class="py-12 md:py-16">
    <article class="mx-auto max-w-3xl">
      <nav class="mb-6 text-sm font-semibold text-gray-500" aria-label="面包屑">
        <a class="hover:text-violet-700" href="/zh/m3u8-player">M3U8在线播放器</a>
        <span class="mx-2 text-gray-300">/</span>
        <a class="hover:text-violet-700" href="/zh/guides">指南</a>
      </nav>

      <header class="mb-8">
        <p class="mb-3 text-sm font-extrabold text-violet-700">{article.category}</p>
        <h1 class="text-3xl font-black leading-tight text-gray-950 md:text-4xl">{article.h1}</h1>
        <p class="mt-4 text-lg font-medium leading-relaxed text-gray-600">{article.summary}</p>
        <p class="mt-3 text-sm font-semibold text-gray-500">最后更新：{article.dateModified}</p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <Button href="/zh/m3u8-player" variant="primary">打开M3U8在线播放器</Button>
          <Button href="/zh/guides" variant="secondary">全部指南</Button>
        </div>
      </header>

      <div class="guide-prose">
        <h2>第一步：确认这是直接 M3U8 链接</h2>
        <p>
          在线测试 M3U8直播流 时，应该使用真实的 `.m3u8` 播放列表地址，而不是普通网页地址、视频详情页或 iframe 页面。有效播放列表通常包含 `#EXTM3U` 等 HLS 标签。
        </p>

        <h2>第二步：确认你有测试权限</h2>
        <p>
          请只测试公开或已授权的 M3U8直播源、M3U8直播流 或 HLS 视频流。不要测试未经授权、带敏感 token、需要登录或明确限制外部播放的链接。
        </p>

        <h2>第三步：在浏览器中播放</h2>
        <p>
          把链接粘贴到中文 M3U8在线播放器，点击播放。浏览器会尝试加载播放列表和媒体分片。如果能正常加载，播放器会显示视频；如果失败，播放日志可以提供线索。
        </p>

        <h2>第四步：阅读播放日志</h2>
        <p>
          播放日志可以帮助判断问题更接近播放列表、分片、CORS、编码、MIME、CDN、服务器响应或访问权限。它是浏览器本地播放的参考，不是完整的服务器诊断报告。
        </p>

        <h2>常见失败点</h2>
        <ul>
          <li>M3U8 链接返回 HTML、登录页或错误页。</li>
          <li>播放列表能加载，但分片请求失败。</li>
          <li>浏览器被 CORS 阻止访问播放资源。</li>
          <li>视频编码或音频编码不被当前浏览器支持。</li>
          <li>直播源过期、不可用或只允许特定来源访问。</li>
        </ul>
      </div>

      <aside class="mt-10 rounded-xl border border-orange-100 bg-white/82 p-5 shadow-sm shadow-orange-100/50">
        <h2 class="text-lg font-black text-gray-950">测试边界</h2>
        <p class="mt-2 text-sm font-medium leading-relaxed text-gray-600">
          本工具用于浏览器侧播放测试，不提供下载、转换、解析、抓取或绕过访问控制功能。私有或签名链接应由来源站提供合法授权流程。
        </p>
      </aside>
    </article>
  </Container>
</BaseLayout>
