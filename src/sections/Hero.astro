---
// Hero 区块 - 1:1 对齐 UI/home.png 首屏结构，包含标题、描述、CTA、标签和插图
import { hero } from '../config/home.js';
import Button from '../components/Button.astro';
import Icon from '../components/Icon.astro';
import Container from '../components/Container.astro';
---

<section class="relative overflow-hidden pt-5 pb-4 md:pt-9 md:pb-4">
  <Container variant="hero">
    <div class="grid grid-cols-1 md:grid-cols-[1.04fr_0.96fr] items-center gap-6 md:gap-3">
      {/* 左侧文案区：宽度、行高和按钮尺寸按设计图首屏比例设置 */}
      <div class="order-2 md:order-1 max-w-[464px]">
        <div class="inline-flex items-center rounded-full bg-violet-100/75 px-3 py-1.5 mb-3 shadow-sm shadow-violet-100 md:px-4 md:py-2 md:mb-4">
          <span class="text-[12px] md:text-[14px] font-extrabold text-violet-700 leading-none">{hero.badge}</span>
        </div>

        {/* H1 - 首页唯一主标题，英文文案从配置读取，重点词使用设计图紫色渐变 */}
        <h1 class="text-[22px] min-[390px]:text-[24px] md:text-[31px] font-black leading-[1.08] tracking-[-0.055em] text-gray-950 mb-3 md:mb-4">
          <span><span>{hero.titlePrefix}</span><span class="mt-gradient-text">{hero.titleHighlight}</span><span>{hero.titleSuffix}</span></span><br />
          <span>{hero.titleSecondLine}</span>
        </h1>

        <p class="text-[13px] md:text-[15px] font-semibold text-gray-800 leading-snug md:leading-[1.55] mb-4 md:mb-6 max-w-[435px]">
          {hero.description}
        </p>

        {/* CTA 按钮均使用 Button 组件，避免页面直接写按钮元素 */}
        <div class="flex flex-nowrap items-center gap-2 mb-4 md:flex-wrap md:gap-4 md:mb-6">
          <Button href={hero.primaryCta.href} variant="primary" size="lg" class="h-[36px] min-w-0 flex-1 px-3 py-0 text-[13px] md:min-w-[145px] md:flex-none md:h-[45px] md:px-7 md:text-base">
            {hero.primaryCta.label}
            <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-white text-violet-700 md:h-6 md:w-6">
              <Icon name="ArrowRight" size={15} strokeWidth={2.8} />
            </span>
          </Button>
          <Button href={hero.secondaryCta.href} variant="secondary" size="lg" class="h-[36px] min-w-0 flex-1 px-3 py-0 text-[13px] md:min-w-[184px] md:flex-none md:h-[45px] md:px-7 md:text-base">
            {hero.secondaryCta.label}
            <Icon name="CirclePlay" size={18} strokeWidth={2.4} />
          </Button>
        </div>

        {/* 特性标签：图标、颜色和文案都来自配置，贴近设计图四个胶囊标签 */}
        <div class="grid grid-cols-4 gap-1.5 md:flex md:flex-wrap md:gap-2">
          {hero.chips.map((chip) => (
            <span class="inline-flex min-w-0 items-center justify-center gap-0.5 h-[26px] px-1 rounded-lg bg-white/90 border border-orange-100 shadow-sm shadow-orange-100/50 text-[12px] font-extrabold text-gray-800 md:gap-1.5 md:h-[28px] md:px-2.5 md:rounded-xl">
              <Icon name={chip.icon} size={11} color={chip.color} strokeWidth={2.4} class="md:hidden" /><Icon name={chip.icon} size={15} color={chip.color} strokeWidth={2.4} class="hidden md:block" />
              {chip.label}
            </span>
          ))}
        </div>
      </div>

      {/* 右侧插图只使用 public/imgs 既有素材，不把 UI 图当背景 */}
      <div class="order-1 md:order-2 flex justify-center md:justify-end">
        <div class="relative h-[190px] w-full max-w-[300px] md:h-[305px] md:max-w-[472px]">
          <img
            src={hero.image}
            alt={hero.imageAlt}
            width="510"
            height="510"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="absolute left-1/2 top-1/2 w-[285px] max-w-none -translate-x-1/2 -translate-y-1/2 md:w-[405px] md:-translate-x-[50%] md:-translate-y-[52%] drop-shadow-[0_22px_34px_rgba(119,71,255,0.10)]"
          />
        </div>
      </div>
    </div>
  </Container>
</section>
