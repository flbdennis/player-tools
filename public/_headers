# Cloudflare Pages 响应头配置 - 只匹配项目真实存在的发布路径

# 全站安全头 - 不设置 X-Frame-Options，避免破坏播放器 iframe 嵌入能力
/*
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff

# 哈希化静态资源 - Astro 构建产物文件名带 hash，可长期缓存
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# 图片和 Logo 资源 - 文件名稳定，后续替换素材时通过重新部署刷新
/imgs/*
  Cache-Control: public, max-age=31536000

/logo/*
  Cache-Control: public, max-age=31536000

/og/*
  Cache-Control: public, max-age=31536000

# HTML 页面 - 静态页面变化时允许边缘节点较快重新验证
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

# 搜索引擎、广告审核和站点地图文件 - 使用真实 lowercase 路径
/robots.txt
  Cache-Control: public, max-age=86400

/sitemap.xml
  Cache-Control: public, max-age=86400

/ads.txt
  Cache-Control: public, max-age=86400

/google12a4140ea0c83294.html
  Cache-Control: public, max-age=86400
